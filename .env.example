# Cloudflare D1 - Required for drizzle-kit
# Get these from your Cloudflare dashboard
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_DATABASE_ID=""
CLOUDFLARE_D1_TOKEN=""

PUBLIC_POSTHOG_PROJECT_TOKEN=""
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
