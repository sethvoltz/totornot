{
	"name": "totornot",
	"private": true,
	"version": "1.8.0",
	"type": "module",
	"packageManager": "pnpm@10.23.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "pnpm run build && wrangler dev --local --port 4173",
		"prepare": "husky",
		"clean": "rm -rf .svelte-kit",
		"check": "rm -rf .svelte-kit/output && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "rm -rf .svelte-kit/output && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm test:unit -- --run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"test:storybook": "vitest --config vitest.storybook.config.ts",
		"gen": "wrangler types && pnpm gen:paraglide",
		"gen:paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:staging": "wrangler d1 migrations apply totornot-staging --env staging --remote",
		"db:migrate:production": "wrangler d1 migrations apply totornot --remote",
		"db:studio": "drizzle-kit studio",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"lighthouse": "node scripts/lighthouse.js",
		"lighthouse:view": "lhci open",
		"deploy": "wrangler deploy",
		"deploy:staging": "wrangler deploy --env staging"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.1",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.10.0",
		"@lhci/cli": "0.14.0",
		"@playwright/test": "^1.58.2",
		"@storybook/addon-a11y": "^10.3.3",
		"@storybook/addon-docs": "^10.3.3",
		"@storybook/addon-svelte-csf": "^5.1.1",
		"@storybook/addon-vitest": "^10.3.3",
		"@storybook/sveltekit": "^10.3.3",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^25.5.2",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"chrome-launcher": "^1.2.1",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.3.3",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lighthouse": "^13.0.3",
		"lint-staged": "^16.4.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.3.3",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2",
		"wrangler": "^4.63.0"
	},
	"dependencies": {
		"posthog-js": "^1.367.0",
		"posthog-node": "^5.29.2"
	}
}
